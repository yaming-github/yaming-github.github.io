---
interface Props {
  start: string
  end?: string | null
  override?: string
}

const { start, end, override } = Astro.props

function format(start: string, end: string | null | undefined): string {
  const s = start.slice(0, 4)
  if (!end) return `${s} — Now`
  const e = end.slice(0, 4)
  return s === e ? s : `${s} — ${e}`
}
---

<span>{override ?? format(start, end)}</span>
